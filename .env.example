# ─────────────────────────────────────────────────────────────
# Rezumix environment variables
# Copy this file to `.env.local` and fill in real values.
# Never commit `.env.local` or real secrets.
# ─────────────────────────────────────────────────────────────

# Database
MONGODB_URI=your_mongodb_connection_string

# NextAuth.js
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret
# Base URL of the app. Use http://localhost:3000 in development and your
# deployed origin (e.g. https://rezumix.example.com) in production.
NEXTAUTH_URL=http://localhost:3000

# Google OAuth 2.0 (Continue with Google)
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret

# JWT tokens (legacy credentials helpers on the user model)
ACCESS_TOKEN_SECRET=your_access_token_secret
ACCESS_TOKEN_EXPIRY=1d
REFRESH_TOKEN_SECRET=your_refresh_token_secret
REFRESH_TOKEN_EXPIRY=10d

# Cloudinary (media uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_cloudinary_key
CLOUDINARY_API_SECRET=your_cloudinary_secret

# Email / OTP delivery
EMAIL_USER=your_email_address
EMAIL_PASS=your_email_password

# AI providers
GEMINI_API_KEY=your_google_gemini_api_key

# Public contact email (exposed to the client)
NEXT_PUBLIC_CONTACT_EMAIL=contact@example.com
